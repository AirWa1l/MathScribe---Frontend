# URL base de la API de MathScribe (backend FastAPI).
# En desarrollo, Vite hace proxy de /api hacia el backend (ver vite.config.ts).
VITE_API_BASE_URL=/api/v1

# En producción (Render) se define con la URL pública del backend:
# VITE_API_BASE_URL=https://mathscribe-api.onrender.com/api/v1
# Vite incrusta este valor en el bundle durante el build, así que cambiarlo
# obliga a reconstruir el sitio estático.

# Destino del proxy de /api en desarrollo (npm run dev).
# Debe apuntar al backend FastAPI. En Windows usa 127.0.0.1 (no localhost) para
# evitar que se resuelva a IPv6 (::1) y el proxy no conecte.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
